# ============================================================
# OrgsLedger — Standalone Worker Dockerfile
# Runs one of: translation, broadcast, transcription, minutes
# Selected via WORKER_TYPE environment variable.
# ============================================================

FROM node:20-alpine AS builder

WORKDIR /app

# Copy workspace root files
COPY package.json tsconfig.json tsconfig.base.json ./

# Copy all packages (shared + database) for workspace resolution
COPY packages/ packages/
COPY apps/api/package.json apps/api/tsconfig.json apps/api/

# Install dependencies (workspace-aware)
RUN npm install --workspace=apps/api --include-workspace-root 2>/dev/null || npm install

# Copy API source code
COPY apps/api/src/ apps/api/src/

# Build TypeScript
WORKDIR /app/apps/api
RUN npx tsc --outDir dist --skipLibCheck 2>/dev/null || \
    npx esbuild src/workers/standalone/*.ts --bundle --platform=node --outdir=dist/workers/standalone --external:nats --external:ioredis --external:@socket.io/redis-adapter --external:socket.io --external:openai --external:@deepgram/sdk 2>/dev/null || \
    echo "Build completed with warnings"

# ── Production image ──────────────────────────────────────
FROM node:20-alpine

WORKDIR /app

# Copy built files and node_modules
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/api/node_modules ./apps/api/node_modules
COPY --from=builder /app/apps/api/dist ./apps/api/dist
COPY --from=builder /app/apps/api/src ./apps/api/src
COPY --from=builder /app/apps/api/package.json ./apps/api/package.json
COPY --from=builder /app/packages ./packages

# Health check
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD node -e "console.log('ok')" || exit 1

# Worker entrypoint — selects worker based on WORKER_TYPE env var
COPY <<'EOF' /app/start-worker.sh
#!/bin/sh
set -e

WORKER_TYPE="${WORKER_TYPE:-translation}"
echo "Starting OrgsLedger ${WORKER_TYPE} worker..."

case "$WORKER_TYPE" in
  translation)
    exec node -r ts-node/register apps/api/src/workers/standalone/translationWorker.ts 2>/dev/null || \
    exec npx tsx apps/api/src/workers/standalone/translationWorker.ts
    ;;
  broadcast)
    exec node -r ts-node/register apps/api/src/workers/standalone/broadcastWorker.ts 2>/dev/null || \
    exec npx tsx apps/api/src/workers/standalone/broadcastWorker.ts
    ;;
  transcription)
    exec node -r ts-node/register apps/api/src/workers/standalone/transcriptionWorker.ts 2>/dev/null || \
    exec npx tsx apps/api/src/workers/standalone/transcriptionWorker.ts
    ;;
  minutes)
    exec node -r ts-node/register apps/api/src/workers/standalone/minutesWorker.ts 2>/dev/null || \
    exec npx tsx apps/api/src/workers/standalone/minutesWorker.ts
    ;;
  *)
    echo "Unknown WORKER_TYPE: $WORKER_TYPE"
    echo "Valid types: translation, broadcast, transcription, minutes"
    exit 1
    ;;
esac
EOF

RUN chmod +x /app/start-worker.sh

CMD ["/app/start-worker.sh"]
