# ── Server ────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ── Database ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=orgsledger
DB_PASSWORD=orgsledger_dev
DB_NAME=orgsledger

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Extended Redis Configuration (for production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Cluster mode (comma-separated: host1:port1,host2:port2)
REDIS_CLUSTER_NODES=
REDIS_POOL_SIZE=8
REDIS_CONNECT_TIMEOUT_MS=10000

# ── Redis Failover (Production HA) ────────────────
# Mode: standalone | sentinel | cluster
REDIS_MODE=standalone
# Sentinel configuration (comma-separated: host1:26379,host2:26379)
REDIS_SENTINEL_NODES=
REDIS_SENTINEL_MASTER=mymaster
REDIS_SENTINEL_PASSWORD=
# Retry behavior
REDIS_RETRY_DELAY_MS=100
REDIS_MAX_RETRY_DELAY_MS=5000
REDIS_COMMAND_TIMEOUT_MS=5000
REDIS_HEALTH_CHECK_MS=10000

# ── JWT ───────────────────────────────────────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_orgsledger_2025
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX

# ── Paystack ─────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_XXXX
PAYSTACK_PUBLIC_KEY=pk_test_XXXX

# ── Flutterwave ──────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-XXXX
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-XXXX
FLUTTERWAVE_WEBHOOK_HASH=

# ── AI Services ──────────────────────────────────
OPENAI_API_KEY=sk-XXXX
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# ── AI Circuit Breaker (Production Protection) ───
# Failures before opening circuit (fast-fail)
CIRCUIT_OPENAI_FAILURE_THRESHOLD=5
CIRCUIT_OPENAI_TIMEOUT_MS=30000
CIRCUIT_OPENAI_RESET_MS=60000
CIRCUIT_OPENAI_FALLBACK=true
# Deepgram (lower thresholds for real-time transcription)
CIRCUIT_DEEPGRAM_FAILURE_THRESHOLD=3
CIRCUIT_DEEPGRAM_TIMEOUT_MS=10000
CIRCUIT_DEEPGRAM_RESET_MS=30000
CIRCUIT_DEEPGRAM_FALLBACK=true
# Translation
CIRCUIT_TRANSLATION_FAILURE_THRESHOLD=5
CIRCUIT_TRANSLATION_TIMEOUT_MS=15000
CIRCUIT_TRANSLATION_RESET_MS=45000
CIRCUIT_TRANSLATION_FALLBACK=true

# ── LiveKit (Real-time Communication) ────────────
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ── Deepgram (Speech-to-Text) ────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# ── Translation Service ──────────────────────────
# Provider: google | deepl | mock
TRANSLATION_PROVIDER=google
# Target languages (comma-separated ISO 639-1 codes)
TRANSLATION_LANGUAGES=es,fr,de,pt,zh
# DeepL API key (only needed if TRANSLATION_PROVIDER=deepl)
DEEPL_API_KEY=

# ── AI Proxy (optional, for enterprise deployments) ──
AI_PROXY_URL=
AI_PROXY_KEY=

# ── Minutes AI Generation ────────────────────────
MINUTES_AI_MODEL=gpt-4o-mini
MINUTES_MAX_TOKENS=10000

# ── Workers (Horizontal Scaling) ─────────────────
# Unique worker identifier for distributed tracing
WORKER_ID=


# ── Email (SMTP) ─────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@orgsledger.com

# ── File Storage ──────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Firebase Push Notifications ──────────────────
FIREBASE_PROJECT_ID=

# ── CORS (comma-separated, production only) ──────

CORS_ORIGINS=https://orgsledger.com

# ── Admin Seeding (used by database seed script) ──
DEFAULT_ADMIN_EMAIL=admin@orgsledger.com
DEFAULT_ADMIN_PASSWORD=SuperAdmin1234!
